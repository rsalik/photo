# Copy to .env and fill in. All server-only.

# Password for the /admin portal. REQUIRED — the portal is disabled without it.
ADMIN_PASSWORD=change-me

# Secret used to sign admin session cookies. REQUIRED in production (serverless
# has no writable filesystem). If omitted in local dev, a random secret is
# generated and persisted in data/.session-secret on first run.
# SESSION_SECRET=

# --- Database ---------------------------------------------------------------
# Postgres connection string (Neon's POOLED url in production). When unset, the
# app uses an embedded PGlite database under DATA_DIR (offline dev, no service).
# DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# --- Image storage (Cloudflare R2) ------------------------------------------
# When all four are set, images are stored in R2; otherwise they go to local
# disk under DATA_DIR. Uploads run on your laptop, so its .env needs these.
# R2_BUCKET=photo
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# Public CDN base for serving (a custom domain on the bucket). With it set,
# /img/* redirects here; without it, images are proxied through the server.
# R2_PUBLIC_URL=https://cdn.photos.ryansalik.com

# Where PGlite + local-disk images live when the cloud services above are unset.
# DATA_DIR=./data
